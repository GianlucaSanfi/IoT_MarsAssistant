# =============================================================================

API_BASE_URL=http://host.docker.internal:8080

# Polling interval sensori (secondi)
SENSOR_POLL_INTERVAL_SEC=10

# SSE
TELEMETRY_RECONNECT_DELAY_SEC=5
TELEMETRY_STREAM_TIMEOUT_SEC=30

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_EXCHANGE=telemetry
RABBITMQ_SENSOR_ROUTING_KEY=sensors.normalized
RABBITMQ_TELEMETRY_ROUTING_KEY=telemetry.normalized
